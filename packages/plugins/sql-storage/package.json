{
  "name": "verdaccio-sql-storage",
  "version": "1.0.0",
  "description": "Storage plugin for PostgreSQL",
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "author": "Marc Bernard <marc@abappm.com>",
  "license": "MIT",
  "homepage": "https://abappm.com",
  "repository": {
    "type": "https",
    "url": "https://github.com/abapPM/verdaccio-apm-middleware"
  },
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build/"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@verdaccio/core": "8.0.0-next-8.3",
    "dotenv": "^16.4.5",
    "dotenv-expand": "^11.0.6",
    "drizzle-orm": "^0.36.1",
    "lodash": "^4.17.21",
    "postgres": "^3.4.5",
    "postgres-large-object": "^1.0.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@verdaccio/config": "8.0.0-next-8.3",
    "@verdaccio/logger": "8.0.0-next-8.3",
    "@verdaccio/types": "13.0.0-next-8.1",
    "cross-env": "7.0.3",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "scripts": {
    "clean": "rimraf ./build",
    "build": "tsc --resolveJsonModule",
    "db:generate": "drizzle-kit generate --config src/drizzle.config.ts",
    "db:migrate": "cross-env DB_MIGRATING=true tsx src/db/migrate.ts",
    "db:seed": "cross-env DB_SEEDING=true tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio --config src/drizzle.config.ts"
  }
}
