{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "declaration": true,
    "allowJs": false,
    "noImplicitAny": false,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "$/*": ["./*"]
    },
    "rootDir": "./src",
    "outDir": "./build"
  },
  "include": ["src/**/*.ts", "src/db/seeds/data/*.json"],
  "exclude": ["src/**/*.test.ts"]
}
