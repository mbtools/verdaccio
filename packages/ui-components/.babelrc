{
  "extends": "../../.babelrc",
  "plugins": ["@emotion"],
  "presets": [
    [
      "@babel/preset-env",
      {
        "modules": false,
        "targets": {
          "esmodules": true
        }
      }
    ],
    "@babel/preset-react"
  ],
  "sourceMaps": true,
  "ignore": ["src/**/*.stories.tsx", "src/**/*.test.tsx", "src/**/*.test.ts"]
}
