{
  "name": "@verdaccio-pro/database",
  "version": "1.4.2",
  "description": "Database Layer for Verdaccio Pro (Postgres/Drizzle)",
  "keywords": [
    "database",
    "drizzle",
    "postgres",
    "verdaccio",
    "verdaccio-pro"
  ],
  "homepage": "https://verdaccio.pro",
  "bugs": {
    "url": "https://github.com/verdaccio-pro/verdaccio-pro/issues"
  },
  "license": "FSL-1.1-MIT",
  "author": {
    "name": "Marc Bernard",
    "url": "https://github.com/mbtools"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verdaccio-pro/verdaccio-pro.git",
    "directory": "packages/database"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/verdaccio-pro"
  },
  "files": [
    "build"
  ],
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "vite build",
    "test": "cross-env NODE_ENV=test vitest run",
    "db-server:file": "pglite-server --db=local.db",
    "db-server:memory": "pglite-server",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:visualize": "pnpx drizzle-lab visualizer",
    "db:check": "tsx src/db/tools/check.ts",
    "db:migration:recreate": "tsx src/db/tools/_recreate_drizzle_migration.ts",
    "db:migrate": "cross-env DB_MIGRATING=true tsx src/db/tools/migrate.ts",
    "db:seed": "cross-env DB_SEEDING=true tsx src/db/tools/seed.ts",
    "db:reset": "cross-env DB_RESET=true tsx src/db/tools/reset.ts",
    "db:export": "cross-env DB_EXPORTING=true tsx src/db/tools/export.ts",
    "db:import": "cross-env DB_IMPORTING=true tsx src/db/tools/import.ts",
    "db:repair": "tsx src/db/tools/repair.ts"
  },
  "dependencies": {
    "@verdaccio/core": "9.0.0-next-9.20",
    "debug": "4.4.3",
    "dotenv": "17.4.2",
    "drizzle-orm": "1.0.0-rc.4",
    "pg": "8.22.0",
    "zod": "4.4.3"
  },
  "engines": {
    "node": ">=24"
  }
}
